```lua
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local RootPart = Character:WaitForChild("HumanoidRootPart")

local Config = {
    AutoHarvest = true,
    AutoSell = false,
    HarvestDelay = 0.1,
    CollectRange = 50,
    HighlightFruits = true,
}

local Theme = {
    BG      = Color3.fromRGB(10, 14, 20),
    Surface = Color3.fromRGB(17, 24, 32),
    Border  = Color3.fromRGB(30, 40, 55),
    Primary = Color3.fromRGB(34, 197, 94),
    Accent  = Color3.fromRGB(52, 211, 153),
    Danger  = Color3.fromRGB(239, 68, 68),
    Text    = Color3.fromRGB(230, 240, 255),
    SubText = Color3.fromRGB(110, 130, 160),
}

local harvested = 0
local Highlights = {}
local running = true

local function tween(obj, props, dur)
    TweenService:Create(obj, TweenInfo.new(dur or 0.25, Enum.EasingStyle.Quart), props):Play()
end

local function make(class, props, parent)
    local i = Instance.new(class)
    for k, v in pairs(props) do i[k] = v end
    if parent then i.Parent = parent end
    return i
end

local function corner(r, p)
    make("UICorner", { CornerRadius = UDim.new(0, r) }, p)
end

local ScreenGui = make("ScreenGui", {
    Name = "izHub_UI",
    ResetOnSpawn = false,
    ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    DisplayOrder = 999,
}, LocalPlayer.PlayerGui)

local Window = make("Frame", {
    Size = UDim2.new(0, 340, 0, 460),
    Position = UDim2.new(0.5, -170, 0.5, -230),
    BackgroundColor3 = Theme.BG,
    BorderSizePixel = 0,
    ClipsDescendants = true,
}, ScreenGui)
corner(14, Window)
make("UIStroke", { Color = Theme.Border, Thickness = 1.5 }, Window)

make("ImageLabel", {
