}, Scroll)

local function createToggle(label, desc, icon, default, callback)
    local val = default
    local Row = make("Frame", {
        Size = UDim2.new(1, 0, 0, 64),
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
    }, Scroll)
    corner(10, Row)

    local Bubble = make("Frame", {
        Size = UDim2.new(0, 36, 0, 36),
        Position = UDim2.new(0, 12, 0.5, -18),
        BackgroundColor3 = Theme.Border,
        BorderSizePixel = 0,
    }, Row)
    corner(10, Bubble)

    make("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = icon,
        Font = Enum.Font.GothamBold,
        TextSize = 18,
        TextColor3 = Theme.Text,
    }, Bubble)

    make("TextLabel", {
        Size = UDim2.new(1, -120, 0, 20),
        Position = UDim2.new(0, 58, 0, 13),
        BackgroundTransparency = 1,
        Text = label,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, Row)

    make("TextLabel", {
        Size = UDim2.new(1, -120, 0, 16),
        Position = UDim2.new(0, 58, 0, 34),
        BackgroundTransparency = 1,
        Text = desc,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = Theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, Row)

    local PillBG = make("Frame", {
        Size = UDim2.new(0, 44, 0, 24),
        Position = UDim2.new(1, -56, 0.5, -12),
        BackgroundColor3 = val and Theme.Primary or Theme.Border,
        BorderSizePixel = 0,
    }, Row)
    corner(99, PillBG)

    local Knob = make("Frame", {
        Size = UDim2.new(0, 18, 0, 18),
        Position = val and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
    }, PillBG)
    corner(99, Knob)

    local Btn = make("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
    }, Row)

    Btn.MouseButton1Click:Connect(function()
        val = not val
        tween(PillBG, { BackgroundColor3 = val and Theme.Primary or Theme.Border }, 0.2)
        tween(Knob, { Position = val and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9) }, 0.2)
        if callback then callback(val) end
    end)

    Btn.MouseEnter:Connect(function() tween(Row, { BackgroundColor3 = Color3.fromRGB(22, 32, 44) }, 0.15) end)
    Btn.MouseLeave:Connect(function() tween(Row, { BackgroundColor3 = Theme.Surface }, 0.15) end)
end

createToggle("Auto Harvest", "Collect fruits automatically", "🌿", true, function(v)
    Config.AutoHarvest = v
    StatusLabel.Text = v and "Auto-Harvest Active" or "Auto-Harvest Paused"
    tween(StatusDot, { BackgroundColor3 = v and Theme.Primary or Theme.Danger }, 0.2)
end)

createToggle("Auto Sell", "Sell harvested fruits instantly", "💰", false, function(v)
    Config.AutoSell = v
end)

createToggle("Highlight Fruits", "ESP on nearby fruits", "🔆", true, function(v)
    Config.HighlightFruits = v
    if not v then
        for _, h in pairs(Highlights) do if h and h.Parent then h:Destroy() end end
        Highlights = {}
    end
end)

