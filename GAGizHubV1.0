}, SliderRow)

local DelayVal = make("TextLabel", {
    Size = UDim2.new(0,40,0,20), Position = UDim2.new(1,-52,0,10),
    BackgroundTransparency=1, Text="0.1s", Font=Enum.Font.GothamBold,
    TextSize=12, TextColor3=Theme.Accent, TextXAlignment=Enum.TextXAlignment.Right,
}, SliderRow)

local Track = make("Frame", {
    Size = UDim2.new(1,-70,0,6), Position = UDim2.new(0,58,0,44),
    BackgroundColor3=Theme.Border, BorderSizePixel=0,
}, SliderRow)
corner(99, Track)

local Fill = make("Frame", { Size=UDim2.new(0.05,0,1,0), BackgroundColor3=Theme.Primary, BorderSizePixel=0 }, Track)
corner(99, Fill)

local SKnob = make("Frame", {
    Size=UDim2.new(0,14,0,14), Position=UDim2.new(0.05,-7,0.5,-7),
    BackgroundColor3=Color3.fromRGB(255,255,255), BorderSizePixel=0,
}, Track)
corner(99, SKnob)

local dragging = false
SKnob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
UserInputService.InputChanged:Connect(function(i)
    if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
        local pct = math.clamp((i.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
        Config.HarvestDelay = math.floor(pct * 20) / 10
        DelayVal.Text = Config.HarvestDelay .. "s"
        tween(Fill, { Size=UDim2.new(pct,0,1,0) }, 0.05)
        tween(SKnob, { Position=UDim2.new(pct,-7,0.5,-7) }, 0.05)
    end
end)

local ActionBar = make("Frame", {
    Size = UDim2.new(1,-28,0,42),
    Position = UDim2.new(0,14,1,-52),
    BackgroundColor3 = Theme.Surface,
    BorderSizePixel = 0,
}, ContentFrame)
corner(10, ActionBar)

local function makeBtn(txt, color, xScale, xOffset, cb)
    local b = make("TextButton", {
        Size = UDim2.new(xScale,-4,0,30),
        Position = UDim2.new(xOffset,4,0.5,-15),
        BackgroundColor3 = color,
        Text = txt,
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel = 0,
    }, ActionBar)
    corner(8, b)
    b.MouseButton1Click:Connect(cb)
    b.MouseEnter:Connect(function() tween(b,{BackgroundTransparency=0.2},0.15) end)
    b.MouseLeave:Connect(function() tween(b,{BackgroundTransparency=0},0.15) end)
    return b
end

makeBtn("⏹ Stop", Theme.Danger, 0.33, 0, function()
    running = false
    StatusLabel.Text = "Stopped"
    tween(StatusDot, { BackgroundColor3 = Theme.Danger }, 0.2)
end)

makeBtn("▶ Start", Theme.Primary, 0.33, 0.33, function()
    running = true
    Config.AutoHarvest = true
    StatusLabel.Text = "Auto-Harvest Active"
    tween(StatusDot, { BackgroundColor3 = Theme.Primary }, 0.2)
end)

makeBtn("✕ Close", Theme.Border, 0.34, 0.66, function()
    ScreenGui:Destroy()
    running = false
end)

local draggingWindow, dragStart, startPos
TitleBar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingWindow = true
        dragStart = i.Position
        startPos = Window.Position
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then draggingWindow = false end
end)
UserInputService.InputChanged:Connect(function(i)
    if draggingWindow and i.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = i.Position - dragStart
        Window.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

local HarvestRemote = ReplicatedStorage:FindFirstChild("HarvestFruit")
    or ReplicatedStorage:FindFirstChild("Collect")
    or ReplicatedStorage:FindFirstChild("PickFruit")

local function tryHarvest(obj)
    if HarvestRemote then
        HarvestRemote:FireServer(obj)
        return true
    end
    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        fireproximityprompt(prompt)
        return true
    end
    local part = obj:IsA("BasePart") and obj or (obj:IsA("Model") and obj.PrimaryPart)
    if part and RootPart then
        firetouchinterest(RootPart, part, 0)
        task.wait(0.05)
        firetouchinterest(RootPart, part, 1)
        return true
    end
    return false
end

local function clearHighlights()
    for _, h in pairs(Highlights) do if h and h.Parent then h:Destroy() end end
    Highlights = {}
end

local function highlightFruit(obj)
    if not Config.HighlightFruits or Highlights[obj] then return end
    local h = make("SelectionBox", {
        Adornee = obj,
        Color3 = Theme.Primary,
        LineThickness = 0.05,
        SurfaceTransparency = 0.6,
        SurfaceColor3 = Theme.Accent,
    }, workspace)
    Highlights[obj] = h
end

local FRUIT_KEYS = {
    "fruit","berry","apple","mango","grape","orange",
    "harvest","crop","plant","flower","strawberry",
    "watermelon","pineapple","banana","peach","lemon",
}

local function isFruit(name)
    name = name:lower()
    for _, k in ipairs(FRUIT_KEYS) do
        if name:find(k) then return true end
    end
    return false
end

task.spawn(function()
    while running do
        task.wait(Config.HarvestDelay)
        if not Config.AutoHarvest then task.wait(0.5) continue end

        Character = LocalPlayer.Character
        if not Character then task.wait(1) continue end
        RootPart = Character:FindFirstChild("HumanoidRootPart")
        if not RootPart then task.wait(1) continue end

        clearHighlights()

        for _, obj in pairs(workspace:GetDescendants()) do
            if not running or not Config.AutoHarvest then break end
            if isFruit(obj.Name) and (obj:IsA("Model") or obj:IsA("BasePart")) then
                local part = obj:IsA("Model") and obj.PrimaryPart or obj
                if part then
                    local dist = (RootPart.Position - part.Position).Magnitude
                    if dist <= Config.CollectRange then
                        highlightFruit(obj)
                        if tryHarvest(obj) then
                            harvested += 1
                            CountLabel.Text = harvested .. " harvested"
                        end
                    end
                end
            end
            task.wait()
        end
    end
end)
```