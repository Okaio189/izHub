}, SliderRow)
corner(10, SBubble)
make("TextLabel", { Size = UDim2.new(1,0,1,0), BackgroundTransparency=1, Text="⏱", Font=Enum.Font.GothamBold, TextSize=18, TextColor3=Theme.Text }, SBubble)

make("TextLabel", {
    Size = UDim2.new(1,-130,0,20), Position = UDim2.new(0,58,0,10),
