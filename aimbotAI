--!strict
-- Aim Assist Simulation (All-in-One LocalScript)
-- Put in StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- =====================
-- Config
-- =====================
local Config = {
	Enabled = false,
	FOV = 170,                -- pixel radius from screen center
	Smoothness = 0.18,        -- 0.01 -> 1
	MaxDistance = 350,        -- studs
	RequireLineOfSight = true,
	TargetPartName = "Head",  -- fallback -> HumanoidRootPart
	TeamCheck = true,         -- only target other teams if possible
	ShowFOVCircle = true,
}

-- =====================
-- Helpers
-- =====================
local function getCharacter(player: Player): Model?
	return player.Character
end

local function getHumanoid(model: Model): Humanoid?
	return model:FindFirstChildOfClass("Humanoid")
end

local function getRoot(model: Model): BasePart?
	return model:FindFirstChild("HumanoidRootPart") :: BasePart?
end

local function isAlive(model: Model): boolean
	local hum = getHumanoid(model)
	local root = getRoot(model)
	return hum ~= nil and root ~= nil and hum.Health > 0
end

local function isEnemy(player: Player): boolean
	if player == LocalPlayer then
		return false
	end

	if not Config.TeamCheck then
		return true
	end

	-- If Teams are used, skip same-team players
	if LocalPlayer.Team ~= nil and player.Team ~= nil then
		return LocalPlayer.Team ~= player.Team
	end

	-- If no team system, allow targeting
	return true
end

local function hasLineOfSight(targetPart: BasePart, myCharacter: Model): boolean
	if not Config.RequireLineOfSight then
		return true
	end

	local origin = Camera.CFrame.Position
	local direction = targetPart.Position - origin

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {myCharacter, Camera}
	params.IgnoreWater = true

	local result = Workspace:Raycast(origin, direction, params)
	if not result then
		return true
	end

	-- If ray hits target character, still visible
	return result.Instance:IsDescendantOf(targetPart.Parent)
end

local function getBestTargetPart(): BasePart?
	local myChar = getCharacter(LocalPlayer)
	if not myChar or not isAlive(myChar) then
		return nil
	end

	local myRoot = getRoot(myChar)
	if not myRoot then
		return nil
	end

	local viewportCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local bestPart: BasePart? = nil
	local bestScore = math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if isEnemy(plr) then
			local char = getCharacter(plr)
			if char and isAlive(char) then
				local targetPart = char:FindFirstChild(Config.TargetPartName) :: BasePart?
				if not targetPart then
					targetPart = getRoot(char)
				end

				if targetPart then
					local dist = (targetPart.Position - myRoot.Position).Magnitude
					if dist <= Config.MaxDistance then
						local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
						if onScreen then
							local delta = Vector2.new(screenPos.X, screenPos.Y) - viewportCenter
							local pixelDist = delta.Magnitude

							if pixelDist <= Config.FOV and hasLineOfSight(targetPart, myChar) then
								if pixelDist < bestScore then
									bestScore = pixelDist
									bestPart = targetPart
								end
							end
						end
					end
				end
			end
		end
	end

	return bestPart
end

local function aimStep(dt: number)
	if not Config.Enabled then
		return
	end

	local targetPart = getBestTargetPart()
	if not targetPart then
		return
	end

	local camPos = Camera.CFrame.Position
	local desired = CFrame.lookAt(camPos, targetPart.Position)
	local alpha = math.clamp(Config.Smoothness * dt * 60, 0, 1)

	Camera.CFrame = Camera.CFrame:Lerp(desired, alpha)
end

