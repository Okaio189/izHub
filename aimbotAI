local function mkButton(text: string, color: Color3, h: number?): TextButton
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(1, 0, 0, h or 36)
	b.BackgroundColor3 = color
	b.BorderSizePixel = 0
	b.Text = text
	b.Font = Enum.Font.GothamBold
	b.TextSize = 14
	b.TextColor3 = Color3.new(1, 1, 1)
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)
	b.Parent = content
	return b
end

local function mkRow(labelText: string, defaultText: string): TextBox
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 34)
	row.BackgroundColor3 = Color3.fromRGB(32, 36, 52)
	row.BorderSizePixel = 0
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)
	row.Parent = content

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.55, -8, 1, 0)
	label.Position = UDim2.fromOffset(10, 0)
	label.BackgroundTransparency = 1
	label.Text = labelText
	label.Font = Enum.Font.Gotham
	label.TextSize = 13
	label.TextColor3 = Color3.fromRGB(222, 228, 248)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = row

	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0.4, 0, 0.74, 0)
	box.AnchorPoint = Vector2.new(1, 0.5)
	box.Position = UDim2.new(1, -8, 0.5, 0)
	box.BackgroundColor3 = Color3.fromRGB(16, 20, 30)
	box.BorderSizePixel = 0
	box.ClearTextOnFocus = false
	box.Text = defaultText
	box.Font = Enum.Font.GothamSemibold
	box.TextSize = 13
	box.TextColor3 = Color3.fromRGB(245, 246, 255)
	Instance.new("UICorner", box).CornerRadius = UDim.new(0, 8)
	box.Parent = row

	return box
end

local aimBtn = mkButton("AIM: OFF", Color3.fromRGB(64, 98, 255), 38)
local teamBtn = mkButton("TEAM CHECK: ON", Color3.fromRGB(45, 52, 74), 34)
local losBtn = mkButton("LINE OF SIGHT: ON", Color3.fromRGB(45, 52, 74), 34)

local fovBox = mkRow("FOV (px)", tostring(Config.FOV))
local smoothBox = mkRow("Smooth (0-1)", tostring(Config.Smoothness))
local distBox = mkRow("Max Distance", tostring(Config.MaxDistance))

local function refreshAimBtn()
	if Config.Enabled then
		aimBtn.Text = "AIM: ON"
		aimBtn.BackgroundColor3 = Color3.fromRGB(43, 182, 112)
	else
		aimBtn.Text = "AIM: OFF"
		aimBtn.BackgroundColor3 = Color3.fromRGB(64, 98, 255)
	end
end

local function clampNumberBox(box: TextBox, old: number, minV: number, maxV: number): number
	local n = tonumber(box.Text)
	if not n then
		box.Text = tostring(old)
		return old
	end
	n = math.clamp(n, minV, maxV)
	local rounded = math.floor(n * 1000) / 1000
	box.Text = tostring(rounded)
	return rounded
end

aimBtn.MouseButton1Click:Connect(function()
	Config.Enabled = not Config.Enabled
	refreshAimBtn()
end)

teamBtn.MouseButton1Click:Connect(function()
	Config.TeamCheck = not Config.TeamCheck
	teamBtn.Text = "TEAM CHECK: " .. (Config.TeamCheck and "ON" or "OFF")
end)

losBtn.MouseButton1Click:Connect(function()
	Config.RequireLineOfSight = not Config.RequireLineOfSight
	losBtn.Text = "LINE OF SIGHT: " .. (Config.RequireLineOfSight and "ON" or "OFF")
end)

fovBox.FocusLost:Connect(function()
	Config.FOV = clampNumberBox(fovBox, Config.FOV, 20, 800)
end)

smoothBox.FocusLost:Connect(function()
	Config.Smoothness = clampNumberBox(smoothBox, Config.Smoothness, 0.01, 1)
end)

distBox.FocusLost:Connect(function()
	Config.MaxDistance = clampNumberBox(distBox, Config.MaxDistance, 20, 2500)
end)

refreshAimBtn()

-- Toggle panel visibility
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.RightShift then
		frame.Visible = not frame.Visible
	end
end)

